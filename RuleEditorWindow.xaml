<Window x:Class="backgroundControl.RuleEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="规则编辑器" Height="600" Width="800"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="意图规则管理" FontWeight="Bold" Margin="0,0,0,5"/>

        <TextBox x:Name="SearchBox" Grid.Row="1" TextChanged="SearchBox_TextChanged"
                 Margin="0,0,0,10" Padding="6,4">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Setter Property="Text" Value="搜索关键词或命令..."/>
                    <Setter Property="Foreground" Value="Gray"/>
                    <Style.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter Property="Text" Value=""/>
                            <Setter Property="Foreground" Value="Black"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <DataGrid x:Name="RulesGrid" Grid.Row="2" AutoGenerateColumns="False"
                  CanUserAddRows="True" CanUserDeleteRows="True" Margin="0,0,0,10"
                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="100" CanUserSort="False" CanUserReorder="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="⊕" Width="26" Height="22" FontSize="12" Padding="0"
                                        ToolTip="复制行" Margin="0,0,3,0"
                                        Click="CopyRow_Click"/>
                                <Button Content="↑" Width="26" Height="22" FontSize="12" Padding="0"
                                        ToolTip="插入行" Margin="0,0,3,0"
                                        Click="InsertRow_Click"/>
                                <Button Content="✕" Width="26" Height="22" FontSize="12" Padding="0"
                                        ToolTip="删除行"
                                        Click="DeleteRow_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="关键词" Width="*" Binding="{Binding Keywords}"/>
                <DataGridTextColumn Header="telnet私有命令" Width="*" Binding="{Binding Command}"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="保存并排序" Width="100" Margin="0,0,10,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
