<Window x:Class="backgroundControl.RuleEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="规则编辑器" Height="500" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="意图规则管理（关键词用空格或顿号分隔）" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="RulesGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="True"
                  CanUserDeleteRows="True" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="关键词" Width="*" Binding="{Binding Keywords}"/>
                <DataGridTextColumn Header="命令" Width="*" Binding="{Binding Command}"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="保存" Width="80" Margin="0,0,10,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>