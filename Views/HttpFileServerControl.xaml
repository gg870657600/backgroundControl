<UserControl x:Class="backgroundControl.Views.HttpFileServerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="780">
    <UserControl.Resources>
        <Style x:Key="LblStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#34495E"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="BoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
        </Style>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="12">
        <!-- 顶部：配置 + 控制 -->
        <Border DockPanel.Dock="Top" Background="White" Padding="12" CornerRadius="4" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="端口"     Style="{StaticResource LblStyle}"/>
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtPort" Text="8080" Style="{StaticResource BoxStyle}" Margin="0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="根目录"   Style="{StaticResource LblStyle}"/>
                <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,4">
                    <Button Content="浏览…" DockPanel.Dock="Right" Click="BrowseRoot_Click" 
                            Background="#95A5A6" Style="{StaticResource BtnStyle}"/>
                    <TextBox x:Name="TxtRoot" Text="C:\" Style="{StaticResource BoxStyle}"/>
                </DockPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="用户名"   Style="{StaticResource LblStyle}"/>
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtUser" Text="admin" Style="{StaticResource BoxStyle}" Margin="0,4"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="密码"     Style="{StaticResource LblStyle}"/>
                <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="TxtPass" Password="Changeme_123" 
                             Padding="6,4" BorderBrush="#BDC3C7" Margin="0,4"/>

                <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="2" x:Name="BtnStart" Content="▶ 启动"
                        Background="#27AE60" Style="{StaticResource BtnStyle}" Width="100" Height="48"
                        Margin="12,4,0,4" Click="Start_Click"/>
                <Button Grid.Row="2" Grid.Column="2" Grid.RowSpan="2" x:Name="BtnStop"  Content="■ 停止"
                        Background="#E74C3C" Style="{StaticResource BtnStyle}" Width="100" Height="48"
                        Margin="12,4,0,4" Click="Stop_Click" IsEnabled="False"/>
            </Grid>
        </Border>

        <!-- 状态条 -->
        <Border DockPanel.Dock="Top" Background="#ECF0F1" Padding="10,6" Margin="0,0,0,8" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="访问地址: " FontWeight="SemiBold" Foreground="#34495E"/>
                <TextBlock x:Name="TxtUrl" Text="(未启动)" Foreground="#7F8C8D" FontFamily="Consolas"/>
                <Button Content="📋 复制" Click="CopyUrl_Click" Margin="16,0,0,0" Padding="6,2" 
                        Background="#95A5A6" Style="{StaticResource BtnStyle}" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- 日志区 -->
        <Border Background="#2C3E50" CornerRadius="4" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="访问日志" Foreground="#ECF0F1" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ScrollViewer Grid.Row="1" x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="TxtLog" Background="Transparent" Foreground="#ECF0F1"
                             FontFamily="Consolas" FontSize="12" IsReadOnly="True" 
                             BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="True"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </DockPanel>
</UserControl>
