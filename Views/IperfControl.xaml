<UserControl x:Class="backgroundControl.Views.IperfControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <UserControl.Resources>
        <Style x:Key="LblStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Foreground" Value="#34495E"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="BoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="4" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton x:Name="RbClient" Content="客户端模式" IsChecked="True" 
                                 Margin="0,0,20,0" Checked="Mode_Changed"/>
                    <RadioButton x:Name="RbServer" Content="服务端模式" Checked="Mode_Changed"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="服务器地址" Style="{StaticResource LblStyle}"/>
                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TxtHost" Text="127.0.0.1" Style="{StaticResource BoxStyle}" Margin="0,4"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="端口" Style="{StaticResource LblStyle}"/>
                <TextBox   Grid.Row="1" Grid.Column="3" x:Name="TxtPort" Text="5201" Style="{StaticResource BoxStyle}" Margin="0,4"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="测试时长(s)" Style="{StaticResource LblStyle}"/>
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtDuration" Text="10" Style="{StaticResource BoxStyle}" Margin="0,4"/>
                <TextBlock Grid.Row="2" Grid.Column="2" Text="并行流数" Style="{StaticResource LblStyle}"/>
                <TextBox   Grid.Row="2" Grid.Column="3" x:Name="TxtParallel" Text="1" Style="{StaticResource BoxStyle}" Margin="0,4"/>

                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" x:Name="ProtocolRow" Orientation="Horizontal">
                    <TextBlock Text="协议" Style="{StaticResource LblStyle}"/>
                    <ComboBox x:Name="CbProtocol" SelectedIndex="0" Width="80" Margin="0,0,12,0" 
                              VerticalContentAlignment="Center" SelectionChanged="Protocol_Changed">
                        <ComboBoxItem Content="TCP"/>
                        <ComboBoxItem Content="UDP"/>
                    </ComboBox>
                    <TextBlock x:Name="LblBandwidth" Text="带宽" VerticalAlignment="Center" 
                               Foreground="#34495E" FontSize="13" Margin="0,0,8,0" Visibility="Collapsed"/>
                    <TextBox x:Name="TxtBandwidth" Text="100M" Width="80" 
                             Style="{StaticResource BoxStyle}" Visibility="Collapsed"/>
                </StackPanel>

                <Button Grid.Row="0" Grid.Column="4" Grid.RowSpan="4" x:Name="BtnStart" Content="▶ 启动"
                        Background="#27AE60" Style="{StaticResource BtnStyle}" Width="100" Height="60"
                        Margin="12,4,0,4" Click="Start_Click"/>
                <Button Grid.Row="0" Grid.Column="4" Grid.RowSpan="4" x:Name="BtnStop"  Content="■ 停止"
                        Background="#E74C3C" Style="{StaticResource BtnStyle}" Width="100" Height="60"
                        Margin="12,4,0,4" Click="Stop_Click" IsEnabled="False"
                        Visibility="Collapsed"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#ECF0F1" BorderBrush="#DEE2E6" BorderThickness="1,0,1,1" Padding="16,8" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="状态: " Foreground="#7F8C8D" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtStatus" Text="就绪" Foreground="#27AE60" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtResult" Text="" Foreground="#2C3E50" VerticalAlignment="Center" Margin="16,0,0,0"/>
                <TextBlock x:Name="TxtRealtime" Text="" Foreground="#8E44AD" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="14"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="4" Margin="0,8,0,0" Padding="12,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock Text="实时曲线" Foreground="#34495E" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                    <Ellipse Width="10" Height="10" Fill="#E74C3C" Margin="16,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="接收 (Mbps)" Foreground="#34495E" FontSize="12" VerticalAlignment="Center"/>
                    <Ellipse Width="10" Height="10" Fill="#3498DB" Margin="16,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtChartLabel" Text="发送 (Mbps)" Foreground="#34495E" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtChartMax" Text="" Margin="20,0,0,0" Foreground="#7F8C8D" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="2">
                    <Canvas x:Name="ChartCanvas" ClipToBounds="True" SizeChanged="ChartCanvas_SizeChanged">
                        <Polyline x:Name="ChartLine" Stroke="#3498DB" StrokeThickness="2"/>
                    </Canvas>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="#1E1E1E" CornerRadius="4" Margin="0,8,0,0">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto" Margin="8">
                <TextBox x:Name="TxtLog" Background="Transparent" Foreground="#D4D4D4"
                         FontFamily="Consolas, Courier New" FontSize="12" BorderThickness="0"
                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
