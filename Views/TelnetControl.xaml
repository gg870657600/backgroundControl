<UserControl x:Class="backgroundControl.Views.TelnetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:term="clr-namespace:Microsoft.Terminal.Wpf;assembly=Microsoft.Terminal.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#0078D4"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#D83B01"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Telnet 配置 -->
        <Expander Grid.Row="0" IsExpanded="True" Margin="0,0,0,15" Background="Transparent" BorderThickness="0">
            <Expander.Header>
                <Border Background="White" CornerRadius="8" Padding="15">
                    <TextBlock Text="🌐 Telnet 配置" FontWeight="Bold" FontSize="16" Foreground="#2C3E50"/>
                </Border>
            </Expander.Header>
            <Border Style="{StaticResource CardStyle}" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="主机：" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="HostTextBox" Grid.Column="1" Margin="5" Text="192.168.1.1"/>

                    <TextBlock Text="端口：" Grid.Column="2" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="PortTextBox" Grid.Column="3" Margin="5" Width="120" Text="23"/>

                    <TextBlock Text="用户名：" Grid.Row="1" VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="UserTextBox" Grid.Row="1" Grid.Column="1" Margin="5"/>

                    <TextBlock Text="密码：" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="5"/>
                    <PasswordBox x:Name="PasswordBox" Grid.Row="1" Grid.Column="3" Margin="5" Width="120"/>

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="ConnectButton" Content="连接" Style="{StaticResource ModernButton}" Click="ConnectButton_Click"/>
                        <Button x:Name="DisconnectButton" Content="断开" Style="{StaticResource DangerButton}" Click="DisconnectButton_Click" IsEnabled="False"/>
                        <Border Margin="20,0,0,0" Background="#F8F9FA" Padding="8,4" CornerRadius="4">
                            <TextBlock x:Name="StatusText" Text="未连接" Foreground="Red"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Expander>

        <!-- 终端 -->
        <Expander Grid.Row="2" IsExpanded="True">
            <Expander.Header>
                <Border Background="White" CornerRadius="8" Padding="15">
                    <TextBlock Text="💻 Telnet 终端" FontWeight="Bold" FontSize="16" Foreground="#2C3E50"/>
                </Border>
            </Expander.Header>
            <Border Style="{StaticResource CardStyle}" Padding="0">
                <term:TerminalControl
                    x:Name="TerminalControl"
                    Visibility="Visible"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"
                    Margin="0" PreviewKeyDown="TerminalControl_PreviewKeyDown"/>
            </Border>
        </Expander>
    </Grid>
</UserControl>
