<UserControl x:Class="backgroundControl.Views.FtpServerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <UserControl.Resources>
        <Style x:Key="LblStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Foreground" Value="#34495E"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="BoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 配置区 -->
            <RowDefinition Height="Auto"/>  <!-- 状态条 -->
            <RowDefinition Height="*"/>     <!-- 日志 -->
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="4" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="端口"        Style="{StaticResource LblStyle}"/>
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtPort" Text="2121" Style="{StaticResource BoxStyle}" Margin="0,4"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="被动端口起"  Style="{StaticResource LblStyle}"/>
                <TextBox   Grid.Row="0" Grid.Column="3" x:Name="TxtPasvStart" Text="50000" Style="{StaticResource BoxStyle}" Margin="0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="根目录"      Style="{StaticResource LblStyle}"/>
                <DockPanel Grid.Row="1" Grid.Column="1" Margin="0,4">
                    <Button Content="浏览…" DockPanel.Dock="Right" Click="BrowseRoot_Click"
                            Background="#95A5A6" Style="{StaticResource BtnStyle}"/>
                    <TextBox x:Name="TxtRoot" Text="C:\" Style="{StaticResource BoxStyle}"/>
                </DockPanel>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="被动端口止"  Style="{StaticResource LblStyle}"/>
                <TextBox   Grid.Row="1" Grid.Column="3" x:Name="TxtPasvEnd" Text="50100" Style="{StaticResource BoxStyle}" Margin="0,4"/>

                <CheckBox  Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" x:Name="ChkAnonymous"
                           Content="允许匿名登录 (USER=anonymous, 密码任意)" IsChecked="True"
                           Margin="0,8,0,0" VerticalAlignment="Center"/>

                <Button Grid.Row="0" Grid.Column="4" Grid.RowSpan="3" x:Name="BtnStart" Content="▶ 启动"
                        Background="#27AE60" Style="{StaticResource BtnStyle}" Width="100" Height="48"
                        Margin="12,4,0,4" Click="Start_Click"/>
                <Button Grid.Row="0" Grid.Column="4" Grid.RowSpan="3" x:Name="BtnStop"  Content="■ 停止"
                        Background="#E74C3C" Style="{StaticResource BtnStyle}" Width="100" Height="48"
                        Margin="12,4,0,4" Click="Stop_Click" IsEnabled="False"
                        Visibility="Collapsed"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#ECF0F1" BorderBrush="#DEE2E6" BorderThickness="1,0,1,1" Padding="16,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="访问地址: " Foreground="#7F8C8D" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtUrl" Text="(未启动)" Foreground="#95A5A6" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Content="复制" Margin="12,0,0,0" Padding="8,2" Click="CopyUrl_Click"
                        Background="#3498DB" Style="{StaticResource BtnStyle}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="4" Margin="0,12,0,0">
            <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto" Margin="8">
                <TextBox x:Name="TxtLog" Background="Transparent" Foreground="#D4D4D4"
                         FontFamily="Consolas, Courier New" FontSize="12" BorderThickness="0"
                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
