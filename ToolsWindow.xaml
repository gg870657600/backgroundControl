<Window x:Class="backgroundControl.ToolsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:backgroundControl.Views"
        mc:Ignorable="d"
        Title="工具" 
        Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#F0F2F5">
    <DockPanel>
        <!-- 底部状态栏 -->
        <Border DockPanel.Dock="Bottom" Background="#2C3E50" Padding="10,5">
            <TextBlock Foreground="White" FontSize="12">
                <Run Text="HTTP: " />
                <Run x:Name="HttpStatusRun" Text="已停止" Foreground="#E74C3C" FontWeight="Bold" />
                <Run Text="    FTP: " />
                <Run x:Name="FtpStatusRun"  Text="已停止" Foreground="#E74C3C" FontWeight="Bold" />
                <Run Text="    iperf: " />
                <Run x:Name="IperfStatusRun" Text="已停止" Foreground="#E74C3C" FontWeight="Bold" />
            </TextBlock>
        </Border>

        <TabControl Margin="8" Background="#F0F2F5" BorderThickness="0">
            <TabItem Header="📁 文件服务 (HTTP)">
                <views:HttpFileServerControl x:Name="HttpCtrl" 
                    OnStateChanged="HttpCtrl_StateChanged"
                    OnLogAppended="HttpCtrl_LogAppended"/>
            </TabItem>
            <TabItem Header="📂 FTP 服务">
                <views:FtpServerControl x:Name="FtpCtrl"
                    OnStateChanged="FtpCtrl_StateChanged"
                    OnLogAppended="FtpCtrl_LogAppended"/>
            </TabItem>
            <TabItem Header="📊 打流测试 (iperf3)">
                <views:IperfControl x:Name="IperfCtrl"
                    OnStateChanged="IperfCtrl_StateChanged"
                    OnLogAppended="IperfCtrl_LogAppended"/>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
