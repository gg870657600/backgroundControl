<Window x:Class="backgroundControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:backgroundControl"
        mc:Ignorable="d"
        Title="终端助手" 
        Height="850" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition x:Name="SidebarColumn" Width="0"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧边栏切换按钮条 -->
        <Border x:Name="SidebarToggleBorder" Grid.Column="0" Background="#2C3E50" Width="16">
            <Button x:Name="BtnToggleSidebar" Background="Transparent" BorderThickness="0"
                    Foreground="White" FontSize="10" Padding="0"
                    Cursor="Hand" Content="☰"
                    Click="ToggleSidebar_Click"
                    ToolTip="最近连接"/>
        </Border>

        <!-- 侧边栏 -->
        <Border Grid.Column="1" Background="#34495E" Width="200">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#2C3E50" Padding="10,8">
                    <TextBlock Text="最近连接" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                </Border>

                <ListBox x:Name="HistoryList" Grid.Row="1" Background="Transparent"
                         BorderThickness="0" Foreground="White" FontSize="12"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         MouseDoubleClick="HistoryList_DoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#2C3E50" CornerRadius="3" Padding="5,1,5,2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ConnectionType}" Foreground="#95A5A6" FontSize="11"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Ip}" Foreground="#ECF0F1" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="删除" Click="HistoryList_Delete_Click"/>
                            <MenuItem Header="清空全部" Click="HistoryList_ClearAll_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>
            </Grid>
        </Border>

        <!-- 主内容 -->
        <DockPanel Grid.Column="2">
            <Border x:Name="ToolbarBorder" DockPanel.Dock="Top" Background="#2C3E50" Padding="10,5">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="AddSessionButton" 
                            Content="+ 新建SSH会话" 
                            Width="120" Height="30"
                            Style="{StaticResource AddButtonStyle}"
                            Click="AddSessionButton_Click"/>

            <Button x:Name="Btn_NewSerial" Content="新建串口" 
                Style="{StaticResource ModernButton}"
                Click="AddSerialSession_Click"/>

            <Button x:Name="Btn_NewTelnet" Content="新建Telnet"
                Style="{StaticResource ModernButton}"
                Click="AddTelnetSession_Click"/>

                    <Button x:Name="Btn_Tools" Content="🔧 工具"
                        Style="{StaticResource ModernButton}"
                        Click="ToolsButton_Click"
                        ToolTip="HTTP 文件服务 / FTP 服务 / iperf3 打流"/>
                </StackPanel>
            </Border>

            <TabControl x:Name="SessionTabControl" 
                        Background="#F0F2F5"
                        BorderThickness="0"
                        Margin="10"
                        ItemsSource="{Binding SessionItems}">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5,0">
                            <TextBlock Text="{Binding Header}" 
                                       FontWeight="SemiBold" 
                                       Foreground="#2C3E50"
                                       VerticalAlignment="Center"/>
                            <Button Content="✕" 
                                    Visibility="{Binding IsClosable, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Click="CloseTab_Click" 
                                    Tag="{Binding}" 
                                    Width="20" Height="20" Margin="8,0,0,0"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#E74C3C"
                                    FontSize="12"
                                    FontWeight="Bold"/>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding Content}"/>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </DockPanel>
    </Grid>
</Window>
