<Window x:Class="backgroundControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:backgroundControl"
        mc:Ignorable="d"
        Title="SSH 命令助手" 
        Height="850" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <!-- 全局按钮样式 -->
        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <DockPanel>
        <!-- 顶部工具栏 -->
        <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="AddSessionButton" 
                        Content="+ 新建SSH会话" 
                        Width="120" 
                        Height="30"
                        Style="{StaticResource AddButtonStyle}"
                        Click="AddSessionButton_Click"/>

                <Button x:Name="Btn_NewSerial" Content="新建串口" 
                    Style="{StaticResource ModernButton}"
                    Click="AddSerialSession_Click"/>
            </StackPanel>
        </Border>

        <!-- 会话 TabControl -->
        <TabControl x:Name="SessionTabControl" 
                    Background="#F0F2F5"
                    BorderThickness="0"
                    Margin="10"
                    ItemsSource="{Binding SessionItems}">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="5,0">
                        <TextBlock Text="{Binding Header}" 
                                   FontWeight="SemiBold" 
                                   Foreground="#2C3E50"
                                   VerticalAlignment="Center"/>
                        <Button Content="✕" 
                                Visibility="{Binding IsClosable, Converter={StaticResource BoolToVisibilityConverter}}"
                                Click="CloseTab_Click" 
                                Tag="{Binding}" 
                                Width="20" 
                                Height="20" 
                                Margin="8,0,0,0"
                                Cursor="Hand"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#E74C3C"
                                FontSize="12"
                                FontWeight="Bold"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding Content}"/>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </DockPanel>
</Window>